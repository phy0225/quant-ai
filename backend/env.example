# ── LLM 配置（三个参数） ──────────────────────────────────────────
# LLM_API_KEY 留空 = Mock 模式（无需 API Key，随机生成信号，适合开发演示）

# 方式一：OpenAI 官方
LLM_API_URL=
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o

# 方式二：自定义代理 / 国内镜像（填 base_url 即可，Key 和 Model 同上）
# LLM_API_URL=https://your-proxy.com/v1
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-4o

# 方式三：Azure OpenAI
# LLM_API_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# LLM_API_KEY=xxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-4o

# 方式四：任何 OpenAI 兼容接口（Ollama 本地、DeepSeek、通义千问等）
# LLM_API_URL=http://localhost:11434/v1    # Ollama 本地
# LLM_API_KEY=ollama                       # Ollama 随便填
# LLM_MODEL=llama3

# LLM_API_URL=https://api.deepseek.com/v1  # DeepSeek
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_MODEL=deepseek-chat

# ── 数据库 ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./quant_ai.db

# ── 应用 ─────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
