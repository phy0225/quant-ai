# ── LLM 配置 ──────────────────────────────────────────────────────
# 留空 = Mock 模式（随机信号，适合开发）
LLM_API_URL=
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o

# 自定义代理 / DeepSeek 示例：
# LLM_API_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ── 数据源配置 ─────────────────────────────────────────────────────
# 可选值：akshare（默认，免费）| tushare | mock
DATA_PROVIDER=akshare

# Tushare Token（DATA_PROVIDER=tushare 时填写）
# 注册地址：https://tushare.pro
TUSHARE_TOKEN=

# ── 其他 ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./quant_ai.db
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
